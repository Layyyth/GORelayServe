# Together AI Configuration
LLM_PROVIDER_URL=https://api.together.xyz
LLM_PROVIDER_KEY=your_together_api_key_here

# Redis Configuration
# For local Redis with host networking: localhost:6379
# For Docker Redis (full compose): redis:6379
# For remote Redis: 192.168.1.100:6379
REDIS_ADDR=localhost:6379

# Server Port
RELAY_PORT=8080
